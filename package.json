{
  "name": "summer-body",
  "version": "0.0.0",
  "private": true,
  "description": "AI-assisted nutrition tracking mobile app",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "pnpm exec biome check --write --no-errors-on-unmatched"
    ]
  }
}
